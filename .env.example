# Copy this file to .env and fill in your keys

# LLM — Together API (Llama 3.3 70B)
TOGETHER_API_KEY=your_together_api_key_here

# Optional: Discord bot token (only needed if you want Discord interface)
DISCORD_BOT_TOKEN=

# Optional: Override DB (default is local SQLite at data/eros.db)
# DATABASE_URL=postgresql://user:pass@localhost/eros

# Your name — Eros will use this to address you
USER_NAME=Mahika
USER_ID=mahika

# Wake word — Porcupine (recommended for "Hey Eros")
# 1. Free account at console.picovoice.ai → grab your API key
# 2. Go to "Wake Word" → type "hey eros" → train → download hey_eros_windows.ppn
# 3. Fill in both lines below
# Without these, Eros falls back to openWakeWord (say "eros" to wake)
PICOVOICE_API_KEY=
PORCUPINE_KEYWORD_PATH=C:/Users/Mahika/Eros.v2/hey_eros_windows.ppn
